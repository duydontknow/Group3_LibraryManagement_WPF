<Window x:Class="LibraryManagementSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hệ Thống Quản Lý Thư Viện" Height="650" Width="1050"
        WindowStartupLocation="CenterScreen"
        Name="mainWin">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="10,30,10,10">
                <TextBlock Text="LIBRARY SYSTEM" Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <Button Content="📚 Quản lý Sách (A)" Command="{Binding OpenSachCommand}" 
                        Height="50" Margin="0,5" Background="#34495E" Foreground="White" FontSize="16" BorderThickness="0"/>

                <Button Content="🏷️ Quản lý Thể loại (B)" Command="{Binding OpenTheLoaiCommand}" 
                        Height="50" Margin="0,5" Background="#34495E" Foreground="White" FontSize="16" BorderThickness="0"/>

                <Button Content="👥 Quản lý Độc giả (C)" Command="{Binding OpenDocGiaCommand}" 
                        Height="50" Margin="0,5" Background="#34495E" Foreground="White" FontSize="16" BorderThickness="0"/>

                <Button Content="👔 Quản lý Nhân viên (D)" Command="{Binding OpenNhanVienCommand}" 
                        Height="50" Margin="0,5" Background="#34495E" Foreground="White" FontSize="16" BorderThickness="0"/>

                <Button Content="📝 Quản lý Phiếu mượn (E)" Command="{Binding OpenPhieuMuonCommand}" 
                        Height="50" Margin="0,5" Background="#34495E" Foreground="White" FontSize="16" BorderThickness="0"/>

                <Button Content="📊 Báo cáo Thống kê (F)" Command="{Binding OpenThongKeCommand}" 
                        Height="50" Margin="0,5" Background="#34495E" Foreground="White" FontSize="16" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#ECF0F1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#BDC3C7" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <TextBlock Text="BẢNG ĐIỀU KHIỂN CHUNG" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="#34495E"/>
                    <Button Content="Thoát ứng dụng" Command="{Binding LogoutCommand}" CommandParameter="{Binding ElementName=mainWin}"
                            HorizontalAlignment="Right" Width="120" Height="35" Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="20">
                <UniformGrid Columns="3" Height="130" Margin="0,20,0,0">

                    <Border Background="#3498DB" CornerRadius="8" Margin="10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="TỔNG ĐẦU SÁCH" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TongSoSach}" Foreground="White" FontSize="45" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#2ECC71" CornerRadius="8" Margin="10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="ĐỘC GIẢ ĐĂNG KÝ" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TongDocGia}" Foreground="White" FontSize="45" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#E67E22" CornerRadius="8" Margin="10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="ĐANG CHO MƯỢN" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SachDangMuon}" Foreground="White" FontSize="45" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>