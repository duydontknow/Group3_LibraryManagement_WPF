<Window x:Class="LibraryManagementSystem.Views.NhanVienWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Nhân Viên &amp; Tài Khoản" Height="655" Width="1007"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F8F9F9" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,15,0">
            <StackPanel>
                <TextBlock Text="THÔNG TIN NHÂN VIÊN" FontWeight="Bold" FontSize="18" Foreground="#2C3E50" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <TextBlock Text="Họ và tên *" FontWeight="SemiBold" Margin="0,5,0,0"/>
                <TextBox Text="{Binding FullName}" Height="30" Margin="0,5,0,10" Padding="5" VerticalContentAlignment="Center"/>

                <TextBlock Text="Số điện thoại" FontWeight="SemiBold" Margin="0,5,0,0"/>
                <TextBox Text="{Binding Phone}" Height="30" Margin="0,5,0,15" Padding="5" VerticalContentAlignment="Center"/>

                <Separator Margin="0,5,0,15"/>

                <TextBlock Text="Tên đăng nhập *" FontWeight="SemiBold" Foreground="#2980B9" Margin="0,0,0,0"/>
                <TextBox Text="{Binding Username}" Height="30" Margin="0,5,0,10" Padding="5" VerticalContentAlignment="Center"/>

                <TextBlock Text="Mật khẩu *" FontWeight="SemiBold" Foreground="#2980B9" Margin="0,0,0,0"/>
                <TextBox Text="{Binding Password}" Height="30" Margin="0,5,0,15" Padding="5" VerticalContentAlignment="Center"/>

                <CheckBox Content="Cấp quyền Quản trị (Admin)" IsChecked="{Binding IsAdmin}" FontWeight="SemiBold" Foreground="#C0392B" Margin="0,0,0,25"/>

                <Button Content="➕ Thêm nhân viên" Command="{Binding AddCommand}" Height="40" Background="#2ECC71" Foreground="White" FontWeight="Bold" Margin="0,5"/>
                <Button Content="✏️ Cập nhật" Command="{Binding EditCommand}" Height="40" Background="#F1C40F" Foreground="Black" FontWeight="Bold" Margin="0,5"/>
                <Button Content="🗑️ Xóa nhân viên" Command="{Binding DeleteCommand}" Height="40" Background="#E74C3C" Foreground="White" FontWeight="Bold" Margin="0,5"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Column="1" ItemsSource="{Binding ListNhanVien}" SelectedItem="{Binding SelectedItem}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" Background="White" Margin="0,0,10,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã NV" Binding="{Binding StaffId}" Width="60"/>
                <DataGridTextColumn Header="Họ và Tên" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Số điện thoại" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Tài khoản" Binding="{Binding Account.Username}" Width="120"/>
                
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>