<Window x:Class="LibraryManagementSystem.Views.PhieuMuonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Mượn - Trả Sách" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F8F9F9" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,15,0">
            <StackPanel>
                <TextBlock Text="LẬP PHIẾU MƯỢN" FontWeight="Bold" FontSize="18" Foreground="#2C3E50" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <TextBlock Text="Chọn Độc Giả:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                <ComboBox ItemsSource="{Binding ListDocGia}" SelectedItem="{Binding SelectedReader}" DisplayMemberPath="FullName" Height="30" Margin="0,5,0,15"/>

                <TextBlock Text="Chọn Sách Mượn:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                <ComboBox ItemsSource="{Binding ListSach}" SelectedItem="{Binding SelectedBook}" Height="30" Margin="0,5,0,15">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding Title}" FontWeight="Bold"/>
                                <Run Text=" (Còn: "/>
                                <Run Text="{Binding Quantity}" Foreground="Red"/>
                                <Run Text=" cuốn)"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Hạn Trả Sách:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                <DatePicker SelectedDate="{Binding DueDate}" Height="30" Margin="0,5,0,25"/>

                <Button Content="📚 TIẾN HÀNH MƯỢN SÁCH" Command="{Binding BorrowCommand}" Height="45" Background="#2980B9" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,5"/>
                <TextBlock Text="* Để trả sách, hãy chọn dòng bên phải và bấm nút dưới đây:" TextWrapping="Wrap" Foreground="#7F8C8D" Margin="0,20,0,5" FontStyle="Italic"/>
                <Button Content="✅ XÁC NHẬN TRẢ SÁCH" Command="{Binding ReturnCommand}" Height="45" Background="#27AE60" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,5"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Column="1" ItemsSource="{Binding ListPhieuMuon}" SelectedItem="{Binding SelectedItem}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" Background="White" RowHeight="30">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Phiếu" Binding="{Binding RecordId}" Width="70"/>
                <DataGridTextColumn Header="Người Mượn" Binding="{Binding BorrowRecord.Reader.FullName}" Width="150"/>
                <DataGridTextColumn Header="Sách Mượn" Binding="{Binding Book.Title}" Width="*"/>
                <DataGridTextColumn Header="Ngày Mượn" Binding="{Binding BorrowRecord.BorrowDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                <DataGridTextColumn Header="Hạn Trả" Binding="{Binding DueDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                <DataGridTextColumn Header="Ngày Trả Thực Tế" Binding="{Binding ReturnDate, StringFormat=dd/MM/yyyy}" Width="110"/>
                <DataGridTextColumn Header="Trạng Thái" Binding="{Binding BorrowRecord.Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>

