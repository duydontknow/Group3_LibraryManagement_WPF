<Window x:Class="LibraryManagementSystem.Views.SachWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Sách" Height="550" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F8F9F9" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,15,0">
            <StackPanel>
                <TextBlock Text="THÔNG TIN SÁCH" FontWeight="Bold" FontSize="18" Foreground="#2C3E50" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <TextBlock Text="Tên sách:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                <TextBox Text="{Binding Title}" Height="30" Margin="0,5,0,15" Padding="5"/>

                <TextBlock Text="Tác giả:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                <TextBox Text="{Binding Author}" Height="30" Margin="0,5,0,15" Padding="5"/>

                <TextBlock Text="Số lượng:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                <TextBox Text="{Binding Quantity}" Height="30" Margin="0,5,0,25" Padding="5"/>

                <Button Content="➕ Thêm mới" Command="{Binding AddCommand}" Height="40" Background="#2ECC71" Foreground="White" FontWeight="Bold" Margin="0,5"/>
                <Button Content="✏️ Cập nhật" Command="{Binding EditCommand}" Height="40" Background="#F1C40F" Foreground="Black" FontWeight="Bold" Margin="0,5"/>
                <Button Content="🗑️ Xóa sách" Command="{Binding DeleteCommand}" Height="40" Background="#E74C3C" Foreground="White" FontWeight="Bold" Margin="0,5"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Column="1" ItemsSource="{Binding ListSach}" SelectedItem="{Binding SelectedItem}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Sách" Binding="{Binding BookId}" Width="80"/>
                <DataGridTextColumn Header="Tên sách" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Tác giả" Binding="{Binding Author}" Width="150"/>
                <DataGridTextColumn Header="Số lượng" Binding="{Binding Quantity}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>

