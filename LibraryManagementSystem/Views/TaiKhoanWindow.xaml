<Window x:Class="LibraryManagementSystem.Views.TaiKhoanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Tài Khoản" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F8F9F9" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="THÔNG TIN TÀI KHOẢN" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <TextBlock Text="Tên đăng nhập:" Margin="0,5,0,0"/>
                <TextBox Text="{Binding Username}" Height="30" Margin="0,5,0,15" Padding="5"/>

                <TextBlock Text="Mật khẩu:" Margin="0,5,0,0"/>
                <TextBox Text="{Binding Password}" Height="30" Margin="0,5,0,15" Padding="5"/>

                <TextBlock Text="Vai trò (Quyền):" Margin="0,5,0,0"/>
                <ComboBox ItemsSource="{Binding ListRoles}" DisplayMemberPath="RoleName" SelectedItem="{Binding SelectedRole}" Height="30" Margin="0,5,0,25"/>

                <Button Content="➕ Thêm mới" Command="{Binding AddCommand}" Height="35" Background="#2ECC71" Foreground="White" FontWeight="Bold" Margin="0,5"/>
                <Button Content="✏️ Cập nhật" Command="{Binding EditCommand}" Height="35" Background="#F1C40F" Foreground="Black" FontWeight="Bold" Margin="0,5"/>
                <Button Content="🗑️ Xóa" Command="{Binding DeleteCommand}" Height="35" Background="#E74C3C" Foreground="White" FontWeight="Bold" Margin="0,5"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Column="1" ItemsSource="{Binding ListTaiKhoan}" SelectedItem="{Binding SelectedItem}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã TK" Binding="{Binding AccountId}" Width="60"/>
                <DataGridTextColumn Header="Tên đăng nhập" Binding="{Binding Username}" Width="*"/>
                <DataGridTextColumn Header="Mật khẩu (Hash)" Binding="{Binding PasswordHash}" Width="*"/>
                <DataGridTextColumn Header="Vai trò" Binding="{Binding Role.RoleName}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>