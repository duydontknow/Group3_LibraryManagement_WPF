<Window x:Class="LibraryManagementSystem.Views.TheLoaiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Thể Loại Sách" Height="450" Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F8F9F9" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,15,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="THÔNG TIN THỂ LOẠI" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <TextBlock Text="Tên thể loại:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                <TextBox Text="{Binding CategoryName}" Height="35" Margin="0,5,0,25" Padding="5" VerticalContentAlignment="Center"/>

                <Button Content="➕ Thêm mới" Command="{Binding AddCommand}" Height="40" Background="#2ECC71" Foreground="White" FontWeight="Bold" Margin="0,5"/>
                <Button Content="✏️ Cập nhật" Command="{Binding EditCommand}" Height="40" Background="#F1C40F" Foreground="Black" FontWeight="Bold" Margin="0,5"/>
                <Button Content="🗑️ Xóa" Command="{Binding DeleteCommand}" Height="40" Background="#E74C3C" Foreground="White" FontWeight="Bold" Margin="0,5"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Column="1" ItemsSource="{Binding ListTheLoai}" SelectedItem="{Binding SelectedItem}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã TL" Binding="{Binding CategoryId}" Width="80"/>
                <DataGridTextColumn Header="Tên Thể Loại" Binding="{Binding CategoryName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>